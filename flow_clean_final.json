{
  "version": "7.1",
  "data_api_version": "3.0",
  "routing_model": {
    "PILIH_TIPE": [
      "PILIH_KAMPANYE"
    ],
    "PILIH_KAMPANYE": [
      "PILIH_NOMINAL"
    ],
    "PILIH_NOMINAL": [
      "DATA_DONATUR"
    ],
    "DATA_DONATUR": [
      "KONFIRMASI"
    ],
    "KONFIRMASI": [
      "SELESAI"
    ],
    "SELESAI": []
  },
  "screens": [
    {
      "id": "PILIH_TIPE",
      "title": "Mulai Donasi",
      "terminal": false,
      "data": {
        "kampanye_list": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "main-content": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  }
                }
              },
              "start": {
                "type": "object",
                "properties": {
                  "image": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "__example__": [
            {
              "id": "5733",
              "main-content": {
                "title": "DARURAT, Panti Tunanetra",
                "description": "Terkumpul 81%"
              },
              "start": {
                "image": "iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNk+A8AAQUAAarVyFEAAAAASUVORK5CYII="
              }
            },
            {
              "id": "6246",
              "main-content": {
                "title": "Wajah Hancur Digerogoti Tumor",
                "description": "Terkumpul 74%"
              },
              "start": {
                "image": "iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNk+A8AAQUAAarVyFEAAAAASUVORK5CYII="
              }
            },
            {
              "id": "6835",
              "main-content": {
                "title": "Bantu Revo Sembuh Wajah Membe",
                "description": "Terkumpul 66%"
              },
              "start": {
                "image": "iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNk+A8AAQUAAarVyFEAAAAASUVORK5CYII="
              }
            }
          ]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Donasi via WhatsApp"
          },
          {
            "type": "TextBody",
            "text": "Selamat datang di Raihmimpi! Pilih tipe donasi Anda."
          },
          {
            "type": "RadioButtonsGroup",
            "label": "Tipe Donasi",
            "required": true,
            "name": "tipe_donasi",
            "data-source": [
              {
                "id": "sekali",
                "title": "Donasi Sekali",
                "description": "Donasi satu kali ke kampanye pilihan"
              },
              {
                "id": "rutin",
                "title": "Donasi Rutin",
                "description": "Donasi setiap bulan secara otomatis"
              }
            ]
          },
          {
            "type": "Footer",
            "label": "Pilih Kampanye",
            "on-click-action": {
              "name": "navigate",
              "next": {
                "type": "screen",
                "name": "PILIH_KAMPANYE"
              },
              "payload": {
                "tipe_donasi": "${form.tipe_donasi}",
                "kampanye_list": "${data.kampanye_list}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "PILIH_KAMPANYE",
      "title": "Pilih Kampanye",
      "terminal": false,
      "data": {
        "tipe_donasi": {
          "type": "string",
          "__example__": "sekali"
        },
        "kampanye_list": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "main-content": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  }
                }
              },
              "start": {
                "type": "object",
                "properties": {
                  "image": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "__example__": [
            {
              "id": "5733",
              "main-content": {
                "title": "DARURAT, Panti Tunanetra",
                "description": "Terkumpul 81%"
              },
              "start": {
                "image": "iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNk+A8AAQUAAarVyFEAAAAASUVORK5CYII="
              }
            },
            {
              "id": "6246",
              "main-content": {
                "title": "Wajah Hancur Digerogoti Tumor",
                "description": "Terkumpul 74%"
              },
              "start": {
                "image": "iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNk+A8AAQUAAarVyFEAAAAASUVORK5CYII="
              }
            },
            {
              "id": "6835",
              "main-content": {
                "title": "Bantu Revo Sembuh Wajah Membe",
                "description": "Terkumpul 66%"
              },
              "start": {
                "image": "iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNk+A8AAQUAAarVyFEAAAAASUVORK5CYII="
              }
            }
          ]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "NavigationList",
            "name": "kampanye_nav",
            "list-items": "${data.kampanye_list}",
            "on-click-action": {
              "name": "navigate",
              "next": {
                "type": "screen",
                "name": "PILIH_NOMINAL"
              },
              "payload": {
                "tipe_donasi": "${data.tipe_donasi}",
                "kampanye_id": "${item.id}",
                "kampanye_nama": "${item.main-content.title}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "PILIH_NOMINAL",
      "title": "Pilih Nominal",
      "terminal": false,
      "data": {
        "tipe_donasi": {
          "type": "string",
          "__example__": "sekali"
        },
        "kampanye_id": {
          "type": "string",
          "__example__": "5733"
        },
        "kampanye_nama": {
          "type": "string",
          "__example__": "DARURAT, Panti Tunanetra"
        },
        "show_nominal_lain": {
          "type": "boolean",
          "__example__": false
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Pilih Nominal Donasi"
          },
          {
            "type": "TextBody",
            "text": "Pilih nominal atau masukkan jumlah lain."
          },
          {
            "type": "RadioButtonsGroup",
            "label": "Nominal Donasi",
            "required": true,
            "name": "nominal",
            "data-source": [
              {
                "id": "30000",
                "title": "Rp 30.000"
              },
              {
                "id": "50000",
                "title": "Rp 50.000"
              },
              {
                "id": "100000",
                "title": "Rp 100.000"
              },
              {
                "id": "200000",
                "title": "Rp 200.000"
              },
              {
                "id": "500000",
                "title": "Rp 500.000"
              },
              {
                "id": "0",
                "title": "Nominal Lainnya"
              }
            ],
            "on-select-action": {
              "name": "data_exchange",
              "payload": {
                "tipe_donasi": "${data.tipe_donasi}",
                "kampanye_id": "${data.kampanye_id}",
                "kampanye_nama": "${data.kampanye_nama}",
                "nominal": "${form.nominal}",
                "show_nominal_lain": "${form.nominal == \"0\"}"
              }
            }
          },
          {
            "type": "TextInput",
            "label": "Nominal Lainnya",
            "input-type": "number",
            "name": "nominal_lain",
            "required": false,
            "helper-text": "Masukkan jumlah donasi Anda",
            "visible": "${data.show_nominal_lain}"
          },
          {
            "type": "Footer",
            "label": "Isi Data Donatur",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "tipe_donasi": "${data.tipe_donasi}",
                "kampanye_id": "${data.kampanye_id}",
                "kampanye_nama": "${data.kampanye_nama}",
                "nominal": "${form.nominal}",
                "nominal_lain": "${form.nominal_lain}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "DATA_DONATUR",
      "title": "Data Donatur",
      "terminal": false,
      "data": {
        "tipe_donasi": {
          "type": "string",
          "__example__": "sekali"
        },
        "kampanye_id": {
          "type": "string",
          "__example__": "5733"
        },
        "nominal": {
          "type": "string",
          "__example__": "50000"
        },
        "nominal_lain": {
          "type": "number",
          "__example__": 0
        },
        "kampanye_nama": {
          "type": "string",
          "__example__": "DARURAT, Panti Tunanetra"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Data Donatur"
          },
          {
            "type": "TextBody",
            "text": "Lengkapi data Anda untuk bukti donasi."
          },
          {
            "type": "TextInput",
            "label": "Nama lengkap",
            "input-type": "text",
            "name": "nama_donatur",
            "required": true,
            "helper-text": "Sesuai identitas Anda"
          },
          {
            "type": "TextInput",
            "label": "Atas nama (opsional)",
            "input-type": "text",
            "name": "atas_nama",
            "required": false,
            "helper-text": "Jika donasi untuk orang lain"
          },
          {
            "type": "CheckboxGroup",
            "label": "Persetujuan",
            "required": true,
            "name": "persetujuan",
            "data-source": [
              {
                "id": "setuju",
                "title": "Saya setuju & donasi"
              }
            ]
          },
          {
            "type": "Footer",
            "label": "Lihat Konfirmasi",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "tipe_donasi": "${data.tipe_donasi}",
                "kampanye_id": "${data.kampanye_id}",
                "nominal": "${data.nominal}",
                "nominal_lain": "${data.nominal_lain}",
                "nama_donatur": "${form.nama_donatur}",
                "atas_nama": "${form.atas_nama}",
                "kampanye_nama": "${data.kampanye_nama}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "KONFIRMASI",
      "title": "Konfirmasi Donasi",
      "terminal": false,
      "data": {
        "tipe_donasi": {
          "type": "string",
          "__example__": "sekali"
        },
        "kampanye_id": {
          "type": "string",
          "__example__": "5733"
        },
        "nominal": {
          "type": "string",
          "__example__": "50000"
        },
        "nominal_lain": {
          "type": "number",
          "__example__": 0
        },
        "nama_donatur": {
          "type": "string",
          "__example__": "Budi Santoso"
        },
        "atas_nama": {
          "type": "string",
          "__example__": ""
        },
        "kampanye_nama": {
          "type": "string",
          "__example__": "DARURAT, Panti Tunanetra"
        },
        "nominal_display": {
          "type": "string",
          "__example__": "Rp 30.000"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Konfirmasi Donasi"
          },
          {
            "type": "TextBody",
            "text": "Pastikan data Anda sudah benar sebelum lanjut ke pembayaran."
          },
          {
            "type": "TextCaption",
            "text": "Tipe donasi"
          },
          {
            "type": "TextBody",
            "text": "${data.tipe_donasi}"
          },
          {
            "type": "TextCaption",
            "text": "Kampanye"
          },
          {
            "type": "TextBody",
            "text": "${data.kampanye_nama}"
          },
          {
            "type": "TextCaption",
            "text": "Nominal"
          },
          {
            "type": "TextBody",
            "text": "${data.nominal_display}"
          },
          {
            "type": "TextCaption",
            "text": "Nama donatur"
          },
          {
            "type": "TextBody",
            "text": "${data.nama_donatur}"
          },
          {
            "type": "Footer",
            "label": "Lanjut ke Pembayaran",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "tipe_donasi": "${data.tipe_donasi}",
                "kampanye_id": "${data.kampanye_id}",
                "kampanye_nama": "${data.kampanye_nama}",
                "nominal": "${data.nominal}",
                "nominal_lain": "${data.nominal_lain}",
                "nama_donatur": "${data.nama_donatur}",
                "atas_nama": "${data.atas_nama}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "SELESAI",
      "title": "Donasi Berhasil",
      "terminal": true,
      "success": true,
      "data": {
        "payment_url": {
          "type": "string",
          "__example__": "https://app.midtrans.com/snap/v2/vtweb/xxx"
        },
        "order_id": {
          "type": "string",
          "__example__": "RM-20260613-1234"
        },
        "nama_donatur": {
          "type": "string",
          "__example__": "Budi Santoso"
        },
        "kampanye_nama": {
          "type": "string",
          "__example__": "DARURAT, Panti Tunanetra"
        },
        "nominal_display": {
          "type": "string",
          "__example__": "Rp 50.000"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Terima Kasih! 🤲"
          },
          {
            "type": "TextBody",
            "text": "Donasi kakak sedang diproses. Detail donasi dan link pembayaran telah dikirimkan ke WhatsApp kakak."
          },
          {
            "type": "TextBody",
            "text": "Semoga kakak beserta keluarga diberikan kesehatan selalu, segala urusannya selalu dilancarkan, dan apa yang telah di berikan membawa keberkahan untuk kakak beserta keluarga. Aamiin. 🙏"
          },
          {
            "type": "Footer",
            "label": "Selesai",
            "on-click-action": {
              "name": "complete",
              "payload": {}
            }
          }
        ]
      }
    }
  ]
}