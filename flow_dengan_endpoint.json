{
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": {
    "PILIH_TIPE": ["PILIH_KAMPANYE"],
    "PILIH_KAMPANYE": ["PILIH_NOMINAL"],
    "PILIH_NOMINAL": ["DATA_DONATUR"],
    "DATA_DONATUR": ["KONFIRMASI"],
    "KONFIRMASI": []
  },
  "screens": [
    {
      "id": "PILIH_TIPE",
      "title": "Mulai Donasi",
      "terminal": false,
      "data": {
        "kampanye_list": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "__example__": [
            { "id": "1", "title": "Contoh Kampanye", "description": "Terkumpul: Rp 10.000" }
          ]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Donasi via WhatsApp"
          },
          {
            "type": "TextBody",
            "text": "Selamat datang di Raihmimpi! Pilih tipe donasi Anda."
          },
          {
            "type": "RadioButtonsGroup",
            "label": "Tipe Donasi",
            "required": true,
            "name": "tipe_donasi",
            "data-source": [
              {
                "id": "sekali",
                "title": "Donasi Sekali",
                "description": "Donasi satu kali ke kampanye pilihan"
              },
              {
                "id": "rutin",
                "title": "Donasi Rutin",
                "description": "Donasi setiap bulan secara otomatis"
              }
            ]
          },
          {
            "type": "Footer",
            "label": "Pilih Kampanye",
            "on-click-action": {
              "name": "navigate",
              "next": { "type": "screen", "name": "PILIH_KAMPANYE" },
              "payload": {
                "tipe_donasi": "${form.tipe_donasi}",
                "kampanye_list": "${data.kampanye_list}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "PILIH_KAMPANYE",
      "title": "Pilih Kampanye",
      "terminal": false,
      "data": {
        "tipe_donasi": { "type": "string", "__example__": "sekali" },
        "kampanye_list": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "__example__": [
            { "id": "5733", "title": "DARURAT, Panti Tunanetra", "description": "Terkumpul: Rp 812.414.087" },
            { "id": "6246", "title": "Wajah Hancur Digerogoti Tumor", "description": "Terkumpul: Rp 222.862.733" }
          ]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Pilih Kampanye"
          },
          {
            "type": "TextBody",
            "text": "Pilih kampanye yang ingin Anda dukung."
          },
          {
            "type": "RadioButtonsGroup",
            "label": "Kampanye Aktif",
            "required": true,
            "name": "kampanye_id",
            "data-source": "${data.kampanye_list}"
          },
          {
            "type": "Footer",
            "label": "Pilih Nominal",
            "on-click-action": {
              "name": "navigate",
              "next": { "type": "screen", "name": "PILIH_NOMINAL" },
              "payload": {
                "tipe_donasi": "${data.tipe_donasi}",
                "kampanye_id": "${form.kampanye_id}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "PILIH_NOMINAL",
      "title": "Pilih Nominal",
      "terminal": false,
      "data": {
        "tipe_donasi": { "type": "string", "__example__": "sekali" },
        "kampanye_id": { "type": "string", "__example__": "5733" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Pilih Nominal Donasi"
          },
          {
            "type": "TextBody",
            "text": "Pilih nominal atau masukkan jumlah lain."
          },
          {
            "type": "RadioButtonsGroup",
            "label": "Nominal Donasi",
            "required": true,
            "name": "nominal",
            "data-source": [
              { "id": "30000", "title": "Rp 30.000" },
              { "id": "50000", "title": "Rp 50.000" },
              { "id": "100000", "title": "Rp 100.000" },
              { "id": "200000", "title": "Rp 200.000" },
              { "id": "500000", "title": "Rp 500.000" },
              { "id": "0", "title": "Nominal Lainnya" }
            ]
          },
          {
            "type": "TextInput",
            "label": "Nominal lain",
            "input-type": "number",
            "name": "nominal_lain",
            "required": false,
            "helper-text": "Isi jika pilih Nominal Lainnya"
          },
          {
            "type": "Footer",
            "label": "Isi Data Donatur",
            "on-click-action": {
              "name": "navigate",
              "next": { "type": "screen", "name": "DATA_DONATUR" },
              "payload": {
                "tipe_donasi": "${data.tipe_donasi}",
                "kampanye_id": "${data.kampanye_id}",
                "nominal": "${form.nominal}",
                "nominal_lain": "${form.nominal_lain}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "DATA_DONATUR",
      "title": "Data Donatur",
      "terminal": false,
      "data": {
        "tipe_donasi": { "type": "string", "__example__": "sekali" },
        "kampanye_id": { "type": "string", "__example__": "5733" },
        "nominal": { "type": "string", "__example__": "50000" },
        "nominal_lain": { "type": "number", "__example__": 0 }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Data Donatur"
          },
          {
            "type": "TextBody",
            "text": "Lengkapi data Anda untuk bukti donasi."
          },
          {
            "type": "TextInput",
            "label": "Nama lengkap",
            "input-type": "text",
            "name": "nama_donatur",
            "required": true,
            "helper-text": "Sesuai identitas Anda"
          },
          {
            "type": "TextInput",
            "label": "Atas nama (opsional)",
            "input-type": "text",
            "name": "atas_nama",
            "required": false,
            "helper-text": "Jika donasi untuk orang lain"
          },
          {
            "type": "CheckboxGroup",
            "label": "Persetujuan",
            "required": true,
            "name": "persetujuan",
            "data-source": [
              {
                "id": "setuju",
                "title": "Saya setuju & donasi"
              }
            ]
          },
          {
            "type": "Footer",
            "label": "Lihat Konfirmasi",
            "on-click-action": {
              "name": "navigate",
              "next": { "type": "screen", "name": "KONFIRMASI" },
              "payload": {
                "tipe_donasi": "${data.tipe_donasi}",
                "kampanye_id": "${data.kampanye_id}",
                "nominal": "${data.nominal}",
                "nominal_lain": "${data.nominal_lain}",
                "nama_donatur": "${form.nama_donatur}",
                "atas_nama": "${form.atas_nama}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "KONFIRMASI",
      "title": "Konfirmasi Donasi",
      "terminal": true,
      "success": true,
      "data": {
        "tipe_donasi": { "type": "string", "__example__": "sekali" },
        "kampanye_id": { "type": "string", "__example__": "5733" },
        "nominal": { "type": "string", "__example__": "50000" },
        "nominal_lain": { "type": "number", "__example__": 0 },
        "nama_donatur": { "type": "string", "__example__": "Budi Santoso" },
        "atas_nama": { "type": "string", "__example__": "" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Konfirmasi Donasi"
          },
          {
            "type": "TextBody",
            "text": "Pastikan data Anda sudah benar sebelum lanjut ke pembayaran."
          },
          {
            "type": "TextCaption",
            "text": "Tipe donasi"
          },
          {
            "type": "TextBody",
            "text": "${data.tipe_donasi}"
          },
          {
            "type": "TextCaption",
            "text": "ID Kampanye"
          },
          {
            "type": "TextBody",
            "text": "${data.kampanye_id}"
          },
          {
            "type": "TextCaption",
            "text": "Nominal"
          },
          {
            "type": "TextBody",
            "text": "Rp ${data.nominal}"
          },
          {
            "type": "TextCaption",
            "text": "Nama donatur"
          },
          {
            "type": "TextBody",
            "text": "${data.nama_donatur}"
          },
          {
            "type": "Footer",
            "label": "Lanjut ke Pembayaran",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "tipe_donasi": "${data.tipe_donasi}",
                "kampanye_id": "${data.kampanye_id}",
                "kampanye_nama": "${data.kampanye_id}",
                "nominal": "${data.nominal}",
                "nominal_lain": "${data.nominal_lain}",
                "nama_donatur": "${data.nama_donatur}",
                "atas_nama": "${data.atas_nama}"
              }
            }
          }
        ]
      }
    }
  ]
}
